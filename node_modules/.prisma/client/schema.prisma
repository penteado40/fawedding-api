generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Gift {
  id         Int      @id @default(autoincrement())
  name       String
  image      String?
  amazonLink String?
  price      Decimal  @db.Decimal(12, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("gifts")
}

enum RsvpStatus {
  PENDING
  CONFIRMED
  DECLINED
}

model Rsvp {
  id        Int        @id @default(autoincrement())
  name      String
  email     String     @unique
  phone     String
  status    RsvpStatus @default(PENDING)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("rsvps")
}
